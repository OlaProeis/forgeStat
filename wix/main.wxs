<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="forgeStat"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="OlaProeis"
           UpgradeCode="3F5B3C7B-4E8E-4E6E-9F3D-7C8A9B2D4E5F">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perUser"
             Platform="x64" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="forgeStatIcon.exe" SourceFile="$(var.CargoTargetBinDir)\forgeStat.exe" />
    <Property Id="ARPPRODUCTICON" Value="forgeStatIcon.exe" />

    <Feature Id="ProductFeature" Title="forgeStat" Level="1">
      <ComponentRef Id="BinaryComponent" />
      <ComponentRef Id="PathComponent" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="APPLICATIONFOLDER" Name="forgeStat">

          <Component Id="BinaryComponent" Guid="A7B9C3D4-E5F6-7890-1234-567890ABCDEF">
            <File Id="forgeStatEXE"
                  Name="forgeStat.exe"
                  Source="$(var.CargoTargetBinDir)\forgeStat.exe"
                  KeyPath="yes" />
          </Component>

          <Component Id="PathComponent" Guid="B8C0D4E5-F6A8-8901-2345-678901BCDEF0">
            <RegistryValue Root="HKCU"
                           Key="Software\forgeStat"
                           Name="PathAdded"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
            <Environment Id="PATH"
                         Name="PATH"
                         Value="[APPLICATIONFOLDER]"
                         Permanent="no"
                         Part="last"
                         Action="set"
                         System="no" />
          </Component>

        </Directory>
      </Directory>
    </Directory>

  </Product>
</Wix>
